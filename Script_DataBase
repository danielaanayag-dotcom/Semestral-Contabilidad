-- -----------------------------------------------------------
-- Payroll calculation query for the period (one-row per employee)
-- -----------------------------------------------------------

-- Constants used in calculations
SET @jornada_mensual_hours := 195.0; -- horas/mes para la jornada de 45 semanales
SET @horas_extra_factor_weekday := 1.5;
SET @horas_extra_factor_saturday := 2.0;
SET @ss_employee := 0.0975; -- 9.75%
SET @ss_employer := 0.1325; -- 13.25%
SET @edu_employee := 0.0125; -- 1.25%
SET @edu_employer := 0.015;  -- 1.50%
SET @risk_employer := 0.0056; -- 0.56%
SET @bonificacion_quincena := 120.00;

-- Final aggregated payroll result for the period
SELECT
  e.id AS employee_id,
  e.name,
  e.position,
  e.cedula,
  p.description AS period,
  -- Components
  ROUND(e.monthly_salary/2,2) AS base_quincena,
  ROUND(e.monthly_dieta/2,2) AS dieta_quincena,
  ROUND(@bonificacion_quincena,2) AS bonificacion_quincena,
  -- Commission for the period (direct from sales * commission_rate)
  ROUND(IFNULL(s.total_sales * e.commission_rate, 0.00),2) AS commission_quincena,
  -- Hourly rate (approx.)
  ROUND(e.monthly_salary / @jornada_mensual_hours,4) AS hora_valor,
  -- Overtime pay (apply 1.5x weekday, 2.0x saturday)
  ROUND(
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)
  ,2) AS overtime_pay,
  -- Gross
  ROUND(
    (e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)
  ,2) AS salario_bruto_quincena,
  -- Deducciones obligatorias (partes del trabajador)
  ROUND(((
    (e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)
  ) * @ss_employee),2) AS descuento_seguro_social_empleado,
  ROUND((
    ((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)) * @edu_employee
  ),2) AS descuento_seguro_educativo_empleado,
  -- ISR: simplified annualization method
  -- monthly_taxable = monthly_salary + monthly_dieta + (bonif*2) + (commission_quincena * 2)
  ROUND(
    (CASE
      WHEN (
        ( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12
      ) <= 11000 THEN 0.00
      WHEN (
        ( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12
      ) <= 50000 THEN (
          (( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12) - 11000
        ) * 0.15
      ELSE 5850 + ( (( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12) - 50000 ) * 0.25
    END) / 12 / 2
  ,2) AS descuento_isr_quincena,
  -- Other employee discounts (prorrateo mensual -> quincena)
  ROUND(e.monthly_discount / 2,2) AS descuento_conceptos_empresa_quincena,
  -- Total descuentos (empleado)
  ROUND(
    (((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)) * @ss_employee)
    + (((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)) * @edu_employee)
    + ( (CASE
      WHEN (
        ( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12
      ) <= 11000 THEN 0.00
      WHEN (
        ( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12
      ) <= 50000 THEN (
          (( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12) - 11000
        ) * 0.15
      ELSE 5850 + ( (( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12) - 50000 ) * 0.25
    END) / 12 / 2)
    + (e.monthly_discount / 2)
  ,2) AS total_descuentos_empleado_quincena,
  -- Neto a pagar
  ROUND(
    ((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00))
    - (
      (((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
      COALESCE((SELECT SUM(
        CASE WHEN ex.is_saturday = 1
          THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
          ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
        END)
      FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)) * @ss_employee)
      + (((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
      COALESCE((SELECT SUM(
        CASE WHEN ex.is_saturday = 1
          THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
          ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
        END)
      FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)) * @edu_employee)
      + ( (CASE
        WHEN (
          ( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12
        ) <= 11000 THEN 0.00
        WHEN (
          ( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12
        ) <= 50000 THEN (
            (( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12) - 11000
          ) * 0.15
        ELSE 5850 + ( (( (e.monthly_salary) + (e.monthly_dieta) + (@bonificacion_quincena * 2) + (IFNULL(s.total_sales * e.commission_rate,0) * 2) ) * 12) - 50000 ) * 0.25
      END) / 12 / 2)
      + (e.monthly_discount / 2)
    )
  ,2) AS neto_a_pagar_quincena,
  -- Aportes patronales (se calculan sobre la misma base de devengos)
  ROUND((
    ((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)) * @ss_employer
  ),2) AS aporte_patronal_seguro_social,
  ROUND((
    ((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)) * @edu_employer
  ),2) AS aporte_patronal_seguro_educativo,
  ROUND((
    ((e.monthly_salary/2) + (e.monthly_dieta/2) + @bonificacion_quincena + IFNULL(s.total_sales * e.commission_rate,0) +
    COALESCE((SELECT SUM(
      CASE WHEN ex.is_saturday = 1
        THEN ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_saturday
        ELSE ex.hours * (e.monthly_salary / @jornada_mensual_hours) * @horas_extra_factor_weekday
      END)
    FROM extra_hours ex WHERE ex.employee_id = e.id AND ex.period_id = @period_id),0.00)) * @risk_employer
  ),2) AS aporte_patronal_riesgo_profesional
FROM employees e
LEFT JOIN payroll_periods p ON p.id = @period_id
LEFT JOIN sales s ON s.employee_id = e.id AND s.period_id = @period_id
ORDER BY e.id;

