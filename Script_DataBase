-- Payroll schema + seed + calculation for XAMPP (MySQL / MariaDB)
-- Company: LA PROSPERA, S.A. — Quincena: Segunda quincena de junio 2026
-- Assumptions (explicit):
-- * Currency: B/. (treated 1:1 with $)
-- * Jornada mensual usada para cálculo de hora: 45 horas/semana -> 195 horas/mes (45 * 52 / 12 ≈ 195)
-- * Horas extra: 1.5x entre semana, 2.0x sábados
-- * Seguro Social (empleado): 9.75%  Seguro Social (patr): 13.25%
-- * Seguro Educativo (empleado): 1.25%  Seguro Educativo (patr): 1.50%
-- * Riesgo Profesional (patr): 0.56% (aporte patronal, no deducible del trabajador)
-- * Bonificación por quincena aplicable a todos: B/.120
-- * ISR: calculado anualizando la base mensual (incluye salario base, dietas y bonificaciones y comisión estimada a partir de la quincena)
--   Método de cálculo del ISR (simplificado, conforme al ejemplo de la teoría):
--   monthly_taxable = monthly_salary + monthly_dieta + (bonificacion*2) + commission_month_equiv
--   annual_taxable = monthly_taxable * 12
--   annual ISR:
--     if <=11000 -> 0
--     if >11000 and <=50000 -> (annual_taxable - 11000) * 0.15
--     if >50000 -> 5850 + (annual_taxable - 50000) * 0.25
--   ISR retenido en la quincena = (annual_isr / 12) / 2

CREATE DATABASE IF NOT EXISTS prospersa_payroll CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
USE prospersa_payroll;

-- Employees
DROP TABLE IF EXISTS employees;
CREATE TABLE employees (
  id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(200) NOT NULL,
  cedula VARCHAR(50),
  marital_status VARCHAR(50),
  position VARCHAR(100),
  monthly_salary DECIMAL(12,2) NOT NULL DEFAULT 0.00,
  monthly_dieta DECIMAL(12,2) NOT NULL DEFAULT 0.00,
  monthly_discount DECIMAL(12,2) NOT NULL DEFAULT 0.00,
  commission_rate DECIMAL(10,6) NOT NULL DEFAULT 0.0000
) ENGINE=InnoDB;

-- Payroll periods
DROP TABLE IF EXISTS payroll_periods;
CREATE TABLE payroll_periods (
  id INT AUTO_INCREMENT PRIMARY KEY,
  start_date DATE,
  end_date DATE,
  description VARCHAR(200)
) ENGINE=InnoDB;

-- Extra hours entries (one row per extra worked)
DROP TABLE IF EXISTS extra_hours;
CREATE TABLE extra_hours (
  id INT AUTO_INCREMENT PRIMARY KEY,
  employee_id INT NOT NULL,
  work_date DATE NOT NULL,
  hours DECIMAL(6,2) NOT NULL,
  is_saturday TINYINT(1) NOT NULL DEFAULT 0,
  period_id INT,
  FOREIGN KEY (employee_id) REFERENCES employees(id)
) ENGINE=InnoDB;

-- Sales (for commission)
DROP TABLE IF EXISTS sales;
CREATE TABLE sales (
  id INT AUTO_INCREMENT PRIMARY KEY,
  employee_id INT NOT NULL,
  period_id INT,
  total_sales DECIMAL(14,2) NOT NULL DEFAULT 0.00,
  FOREIGN KEY (employee_id) REFERENCES employees(id)
) ENGINE=InnoDB;

